# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Cloudflare R2 credentials
# Find these in the Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name

# Public URL for your R2 bucket (enable public access in the R2 dashboard first)
# Format: https://pub-<hash>.r2.dev  or a custom domain
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Podcast feed metadata
PODCAST_TITLE=My Podcast
PODCAST_AUTHOR=Your Name
